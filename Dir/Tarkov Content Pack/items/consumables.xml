      </StatusEffect>
      <StatusEffect type="OnSecondaryUse" target="This,UseTarget" duration="30" stackable="false" ConditionalComparison="And">
        <Conditional Condition="lte 1" />
        <Conditional huskinfection="lt 50.0" />
