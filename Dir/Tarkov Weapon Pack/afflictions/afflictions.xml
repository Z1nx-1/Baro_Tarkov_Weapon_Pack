<?xml version="1.0" encoding="utf-8"?>
<Afflictions>
  <Affliction name="Pain" identifier="pain" description="Your body aches in pain" type="debuff" limbspecific="false" indicatorlimb="Head" activationthreshold="0.1" treatmentthreshold="1" maxstrength="130" affectmachines="false">
    <Effect minstrength="10" maxstrength="40" minchromaticaberration="0.1" maxchromaticaberration="1" minscreenblur="0.01" maxscreenblur="0.03"></Effect>
    <Effect minstrength="40" maxstrength="70" minchromaticaberration="1" maxchromaticaberration="1.5" minscreenblur="0.03" maxscreenblur="0.07"></Effect>
    <Effect minstrength="70" maxstrength="100" minchromaticaberration="1.5" maxchromaticaberration="3" minscreenblur="0.1" maxscreenblur="0.1"></Effect>
    <Effect minstrength="100" maxstrength="130" minchromaticaberration="3" maxchromaticaberration="5" minscreenblur="0.1" maxscreenblur="0.2"></Effect>
    <icon texture="Content/UI/MainIconsAtlas.png" sourcerect="128,640,128,128" color="139,60,42,255" origin="0,0" />
  </Affliction>
  
  <Affliction name="Painkiller" identifier="painkiller" description="Your body feels relieved" type="resistance" isbuff="true" limbspecific="false" indicatorlimb="Head" activationthreshold="0.1" treatmentthreshold="1" maxstrength="100" affectmachines="false" >
    <Effect minstrength="0" maxstrength="100"
      strengthchange="-1">
	  <StatusEffect target="Character" type="OnActive">
        <Affliction identifier="pain" amount="-100" />
      </StatusEffect>
    </Effect>
	<icon texture="%ModDir%/medical/medical_textures/PainkillersIcon.png" sourcerect="0,0,128,128" color="10,193,114,255" origin="0,0.1" scale="0.1" />
  </Affliction>
  

  <Gas
    name="Gas damage"
    identifier="gasdamage"
    type="gasdamage"
    limbspecific="false"
	indicatorlimb="Head"
    maxstrength="200"
    burnoverlayalpha="0"
    causeofdeathdescription="causeofdeathdescription.damage"
    selfcauseofdeathdescription="self_causeofdeathdescription.damage"
    healcostmultiplier="2.25"
    WeaponsSkillGain="0.5"
    MedicalSkillGain="0.5">
     <Description
      textidentifier="afflictiondescription.gasdamage.low"
      minstrength="0"
      maxstrength="30"/>
    <Description
      textidentifier="afflictiondescription.gasdamage"
      minstrength="30"
      maxstrength="60"/>
    <Description
      textidentifier="afflictiondescription.gasdamage.high"
      minstrength="60"
      maxstrength="200"/>
    <Effect minstrength="0" maxstrength="30" multiplybymaxvitality="true"
      minvitalitydecrease="0"
      maxvitalitydecrease="0.3"/>
    <Effect minstrength="30" maxstrength="60" multiplybymaxvitality="true"
      minvitalitydecrease="0.3"
      maxvitalitydecrease="0.6">
      <StatusEffect target="Limb" interval="5" disabledeltatime="true" ConditionalComparison="And">
        <Conditional IsHuman="true"/>
        <Conditional WorldHostility="gte high" />
